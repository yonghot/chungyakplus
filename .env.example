# =============================================================================
# 청약플러스 환경변수 (.env.example)
# =============================================================================
# 이 파일을 .env.local로 복사하고 실제 값을 입력한다.
# cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase 연결 (필수)
# Supabase 대시보드 > Settings > API 에서 확인
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 서버 전용 — 클라이언트에 노출 금지, RLS 우회 권한
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# 사이트 URL (필수)
# OAuth 콜백 리다이렉트에 사용
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cron 인증 (선택)
# /api/cron/* 엔드포인트 보호용 시크릿
# -----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret-here

# -----------------------------------------------------------------------------
# 공공데이터포털 청약홈 API 인증키 (선택 — Cron 동기화 사용 시 필수)
# 발급: https://www.data.go.kr → "한국부동산원_청약홈 분양정보" 검색 → 활용신청
# 서비스명: ApplyhomeInfoDetailSvc (등록번호: 15006405)
# 주의: 서버 전용 — NEXT_PUBLIC_ 접두사 없음, 클라이언트에 노출 금지
# -----------------------------------------------------------------------------
APPLYHOME_API_KEY=your-applyhome-api-key-here

# -----------------------------------------------------------------------------
# 환경 식별 (선택)
# development | staging | production
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENV=development

# -----------------------------------------------------------------------------
# 지도 타일 스타일 (선택)
# MapLibre GL JS 타일 서버 URL (기본값: CARTO Positron)
# 무료 타일이므로 별도 토큰 불필요
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAP_STYLE=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
